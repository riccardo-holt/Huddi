# Meta API — haal een long-lived token op via developers.facebook.com/tools/explorer
META_ACCESS_TOKEN=plak_hier_je_long_lived_token

# Anthropic API — voor AI advertentieteksten
ANTHROPIC_API_KEY=plak_hier_je_anthropic_api_key

# Dashboard wachtwoord — kies een sterk wachtwoord
DASHBOARD_PASSWORD=kies_een_sterk_wachtwoord

# Auth secret — willekeurige string, houdt sessie-tokens veilig
AUTH_SECRET=genereer_een_willekeurige_string_van_32_tekens

# Server poort (Render stelt dit automatisch in)
PORT=3000
